# Required (Pro tier — leave blank if running free tier only with Ollama)
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=change-me-to-a-random-secret
NCBI_EMAIL=your-email@example.com

# Ollama (free tier LLM — local, zero cost)
# Install: https://ollama.com/download
# Then: ollama serve && ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# Optional
NCBI_API_KEY=                          # increases NCBI rate limit from 3 to 10 req/s
EVO2_NVIDIA_API_KEY=nvapi-...          # for novel sequence generation (rarely used)
# EVO2_USE_LOCAL=true                  # uncomment to use local 7B model instead of NVIDIA API

# Stripe (Pro tier payments — get keys from https://dashboard.stripe.com/apikeys)
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...                  # Create a $29/mo recurring price in Stripe Dashboard
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://progenx.ai

# Defaults (override if needed)
CORS_ORIGINS=http://localhost:5173
# Production: CORS_ORIGINS=https://progenx.ai,https://www.progenx.ai
DATABASE_URL=sqlite:///./protoforge.db
# Production: DATABASE_URL=postgresql://user:pass@host/progenx
